# Allura Memory Integration Configuration
# Copy this file to .env and fill in your actual values

# PostgreSQL Configuration (Allura Episodic Memory)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ronin4life
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=memory

# Neo4j Configuration (Allura Semantic Memory)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Governance Configuration
PROMOTION_MODE=soc2
AUTO_APPROVAL_THRESHOLD=0.85

# MCP Server Path
ALLURA_MCP_SERVER=/home/ronin704/Projects/allura memory/src/mcp/memory-server-canonical.ts

# Tenant Isolation
DEFAULT_GROUP_ID=allura-system